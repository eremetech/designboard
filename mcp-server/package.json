{
  "name": "design-vocabulary-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing the Design Vocabulary Board — UI patterns, prompts, and implementation snippets for AI agents",
  "type": "module",
  "bin": {
    "design-vocabulary-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/data dist/data",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport=stdio",
    "dev": "tsc --watch",
    "extract-data": "node extract-data.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.2"
  }
}
